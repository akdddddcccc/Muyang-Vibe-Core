CORE_HOST=0.0.0.0
CORE_PORT=8787

# Comma-separated browser origins. Include the Vercel acceptance site and the
# unit official site during migration. Never use * in a production environment.
CORS_ORIGIN=https://cmuyang23333.top,https://tool.company.example

# Built-in OFOX adapter for the minimum deployable typography flow.
OFOX_API_KEY=
OFOX_BASE_URL=https://api.ofox.ai/v1
OFOX_IMAGE_MODEL=openai/gpt-image-2
OFOX_IMAGE_QUALITY=low
OFOX_TEXT_LAYER_SIZE=1536x1024

# Optional external unit-owned Adapter. Leave unset to use the built-in path.
OFOX_TYPOGRAPHY_ADAPTER_URL=
OFOX_TYPOGRAPHY_ADAPTER_TOKEN=
